// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}
model User {
  id          String  @id @default(cuid())
  email       String  @unique
  name        String
  role        Role    @default(USER)
  createdAt   DateTime @default(now())
  orders      Order[]
  reservations  Reservation[]
  notifications Notification[]
}
enum Role {
   STAFF
   USER
}
model Menu {
  id          String  @id @default(cuid())
  name        String
  price       Int
  description String
  image       String?
  category    MenuType
  isFeatured Boolean @default(false)
  createdAt   DateTime @default(now())
  orderItems      OrderItem[]
}
enum MenuType {
  COFFEE
  TEA
  DESSERT
  MEAL
}
model Order {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  totalPrice Int
  status     OrderStatus
  isNotified Boolean @default(false) 
  createdAt  DateTime  @default(now())
  Items  OrderItem[]
}
enum OrderStatus {
  PENDING
  READY
  COMPLETED
}
model OrderItem {
  id         String    @id @default(cuid())
  orderId    String
  order      Order    @relation(fields:[orderId],references:[id])
  menuId     String
  menu       Menu     @relation(fields:[menuId],references:[id])
  quantity    Int
}
model Reservation{
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields:[userId],references:[id])
  startTime  DateTime
  status     ReservationType
  isNotified   Boolean  @default(false)
  createdAt  DateTime  @default(now())
}
enum  ReservationType {
  RESERVED
  CANCEL
  COMPLETED
}
model Notification {
  id           String  @id @default(cuid())
  userId       String
  user         User  @relation(fields:[userId],references:[id])
  message      String
  type         NotificationType
  isRead       Boolean
  createdAt    DateTime @default(now())
}
enum NotificationType {
  ORDER_READY
  RESERVATION_AVAILABLE
}
model Constellation{
  id          String  @id @default(cuid())
  name        String
  description String
  season      SeasonType
  magnitude   Float
  shape       String
  image       String?
  createdAt   DateTime @default(now())
}
enum SeasonType{
  SPRING
  SUMMER
  AUTUMN
  WINTER
}